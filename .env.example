# ─────────────────────────────────────────────────────────────────────────
# Vertex Research Labs — environment variables
#
# This is a Vite + React app (NOT Next.js). Client-exposed vars MUST be
# prefixed with VITE_. Server secrets live in Supabase Edge Function secrets
# (Deno) and are NEVER exposed to the client bundle.
# ─────────────────────────────────────────────────────────────────────────

# ---- Client (safe to expose; embedded in the build) ----
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key"
VITE_SUPABASE_PROJECT_ID="your_project_id"

# First-order welcome discount code shown in the popup + welcome email.
# Optional — defaults to "VERTEX10" if unset. Must match the code wired into
# the validate-discount Edge Function.
VITE_DISCOUNT_CODE="VERTEX10"

# ─────────────────────────────────────────────────────────────────────────
# Server-side secrets — set via `supabase secrets set KEY=value`, NOT here.
# Listed for documentation only. Do not commit real values.
#
#   RESEND_API_KEY          # Resend API key (transactional + audience contacts)
#   STRIPE_SECRET_KEY       # Stripe secret key
#   STRIPE_WEBHOOK_SECRET   # Stripe webhook signing secret
#   SUPABASE_URL            # injected into Edge Functions
#   SUPABASE_SERVICE_ROLE_KEY
# ─────────────────────────────────────────────────────────────────────────
